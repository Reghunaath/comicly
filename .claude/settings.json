{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|View|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NoProfile -File .claude/hooks/block-env-local.ps1",
            "timeout": 5
          }
        ]
      }
    ]
  }
}