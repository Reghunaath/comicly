{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NoProfile -File $CLAUDE_PROJECT_DIR/.claude/hooks/file-blocker.ps1",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/frontend-lint.mjs\"",
            "timeout": 45,
            "statusMessage": "Running ESLint & tsc..."
          }
        ]
      }
    ],
    "autoMemoryEnabled": true
  }